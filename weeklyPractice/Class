namespace Object_Oriented_Programming
{
    class Program
    {
        static void Main(string[] args)
        {
            // (i) create employee using default constructor
            Employee emp1 = new Employee();

            // (ii) set attributes using properties
            emp1.Name = "Sarah";
            emp1.Gender = "Female";
            emp1.HourlyRate = 20.5;
            emp1.EmployeeNumber = 101;
            emp1.Nationality = "Irish";

            // (iii) print attributes using ToString()
            Console.WriteLine("Employee 1:");
            Console.WriteLine(emp1.ToString());

            // (iv) create employee using parameterised constructor
            Employee emp2 = new Employee("John", "Male", 25.0, 102);

            // (v) print attributes using ToString()
            Console.WriteLine("\nEmployee 2:");
            emp2.Nationality = "American";
            Console.WriteLine(emp2.ToString());

            // (vi) test calcTax
            double hoursWorked = 40;
            Console.WriteLine($"\n{emp1.Name}'s tax on {hoursWorked} hours is: {emp1.CalcTax(hoursWorked)}");
            Console.WriteLine($"{emp2.Name}'s tax on {hoursWorked} hours is: {emp2.CalcTax(hoursWorked)}");

            // (vii) and (viii) test nationality property
            Employee emp3 = new Employee();
            emp3.Name = "Mike";
            emp3.Nationality = "American";

            Console.WriteLine("\nEmployee 3:");
            Console.WriteLine(emp3.ToString());
        }
    }
}
